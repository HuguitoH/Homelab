#!/bin/bash
# pre-push hook — orchestrates PR creation for develop → main
# Delegates commit detection to GitHub CLI (single source of truth)

export PATH="/usr/bin:/usr/local/bin:$PATH"


# Guard: only run on develop branch
is_develop_branch() {
  [ "$(git branch --show-current)" = "develop" ]
}


# UI: show header with branch info
show_header() {
  echo ""
  gum style \
    --border rounded \
    --border-foreground 99 \
    --padding "1 2" \
    --margin "1 0" \
    "Creating PR: develop → main"
}


# UI: collect PR metadata from user
# Returns: TYPE, TITLE, WHAT, WHY via globals
collect_pr_metadata() {
  TYPE=$(gum choose \
    --header "Type of change:" \
    "feat — new feature" \
    "fix — bug fix" \
    "chore — maintenance" \
    "docs — documentation" \
    "refactor — code refactor")
  TYPE=$(echo "$TYPE" | cut -d' ' -f1)

  TITLE=$(gum input \
    --placeholder "PR title..." \
    --prompt "$TYPE: ")

  WHAT=$(gum write \
    --placeholder "What changed? (Ctrl+D when done)" \
    --header "What changed:")

  WHY=$(gum input \
    --placeholder "Why this change?" \
    --prompt "> ")
}


# UI: show PR preview and ask for confirmation
confirm_pr() {
  local body="$1"
  echo ""
  gum style \
    --border rounded \
    --border-foreground 212 \
    --padding "1 2" \
    "$(echo -e "Title: $TYPE: $TITLE\n\n$body")"
  echo ""
  gum confirm "Create PR and push?"
}

# ─────────────────────────────────────────
# Core: create PR via GitHub CLI
# GitHub CLI is the single source of truth for commit detection.
# If there are no commits between develop and main, gh pr create
# returns "No commits between" and we exit cleanly.
# ─────────────────────────────────────────
create_pr() {
  local body="$1"

  PR_URL=$(gh pr create \
    --base main \
    --head develop \
    --title "$TYPE: $TITLE" \
    --body "$body" 2>&1) || true

  if echo "$PR_URL" | grep -q "No commits between"; then
    gum style --foreground 214 "No new commits vs main — nothing to PR"
    return 1
  fi

  if echo "$PR_URL" | grep -q "already exists"; then
    gum style --foreground 214 "PR already exists — enabling auto-merge"
    PR_URL=$(gh pr list --head develop --base main --state open --json url --jq '.[0].url')
  fi

  echo "$PR_URL"
  return 0
}


# Core: enable auto-merge on PR
# Uses rebase to keep linear history — no merge commits
enable_auto_merge() {
  local pr_url="$1"
  local pr_number
  pr_number=$(echo "$pr_url" | grep -o '[0-9]*$')

  if [ -n "$pr_number" ]; then
    gh pr merge "$pr_number" --auto --rebase --delete-branch=false
    gum style --foreground 82 "PR: $pr_url"
    gum style --foreground 82 "Auto-merge enabled on PR #$pr_number"
  fi
}


# Orchestrator
main() {
  is_develop_branch || exit 0

  show_header
  collect_pr_metadata

  local body
  body="## What
$WHAT

## Why
$WHY

---
*Auto-created by pre-push hook*"

  confirm_pr "$body" || exit 1

  local pr_url
  pr_url=$(create_pr "$body") || exit 0

  enable_auto_merge "$pr_url"
  echo ""
}

main
