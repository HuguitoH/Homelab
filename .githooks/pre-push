#!/bin/bash

export PATH="/usr/bin:/usr/local/bin:$PATH"

BRANCH=$(git branch --show-current)
if [ "$BRANCH" != "develop" ]; then
  exit 0
fi

# Read push refs from stdin
# Read push refs from stdin
read LOCAL_REF LOCAL_SHA_STDIN REMOTE_REF REMOTE_SHA

# Use HEAD as LOCAL_SHA (stdin may be consumed by gum)
LOCAL_SHA=$(git rev-parse HEAD)
if [ -z "$REMOTE_SHA" ]; then
  REMOTE_SHA=$REMOTE_SHA_STDIN
fi

LAST_PR_SHA_FILE="$(git rev-parse --show-toplevel)/.last-pr-sha"

# Get the base to compare against
if [ -f "$LAST_PR_SHA_FILE" ]; then
  BASE_SHA=$(cat "$LAST_PR_SHA_FILE")
else
  BASE_SHA=$(git rev-parse origin/main 2>/dev/null)
fi

# Commits since last PR
COMMITS=$(git log ${BASE_SHA}..${LOCAL_SHA} --pretty=format:"- %s" --no-merges 2>/dev/null | grep -v "sync develop → main" | grep -v "^- Merge ")

if [ -z "$COMMITS" ]; then
  echo "No new commits since last PR — skipping PR creation"
  exit 0
fi

# Commits only in this push
if [ -n "$REMOTE_SHA" ] && [ "$REMOTE_SHA" != "0000000000000000000000000000000000000000" ]; then
  PUSH_COMMITS=$(git log ${REMOTE_SHA}..${LOCAL_SHA} --pretty=format:"- %s" --no-merges 2>/dev/null | grep -v "sync develop → main" | grep -v "^- Merge ")
fi

if [ -z "$PUSH_COMMITS" ]; then
  PUSH_COMMITS="$COMMITS"
fi

echo ""
gum style \
  --border rounded \
  --border-foreground 99 \
  --padding "1 2" \
  --margin "1 0" \
  "Creating PR: develop → main"

echo "Commits in this push:"
echo "$PUSH_COMMITS"
echo ""

TYPE=$(gum choose \
  --header "Type of change:" \
  "feat — new feature" \
  "fix — bug fix" \
  "chore — maintenance" \
  "docs — documentation" \
  "refactor — code refactor")

TYPE=$(echo "$TYPE" | cut -d' ' -f1)

TITLE=$(gum input \
  --placeholder "PR title..." \
  --prompt "$TYPE: ")

WHAT=$(gum write \
  --placeholder "What changed? (Ctrl+D when done)" \
  --header "What changed:")

WHY=$(gum input \
  --placeholder "Why this change?" \
  --prompt "> ")

BODY="## What
$WHAT

## Why
$WHY

## Commits
$PUSH_COMMITS

---
*Auto-created by pre-push hook*"

echo ""
gum style \
  --border rounded \
  --border-foreground 212 \
  --padding "1 2" \
  "$(echo -e "Title: $TYPE: $TITLE\n\n$BODY")"
echo ""

gum confirm "Create PR and push?" || exit 1

PR_URL=$(gh pr create \
  --base main \
  --head develop \
  --title "$TYPE: $TITLE" \
  --body "$BODY" 2>&1) || true

if echo "$PR_URL" | grep -q "already exists"; then
  gum style --foreground 214 "PR already exists — updating auto-merge"
  PR_URL=$(gh pr list --head develop --base main --state open --json url --jq '.[0].url')
fi

if echo "$PR_URL" | grep -q "No commits between"; then
  gum style --foreground 214 "No new commits vs main — skipping PR"
  exit 0
fi

gum style --foreground 82 "PR: $PR_URL"

PR_NUMBER=$(echo "$PR_URL" | grep -o '[0-9]*$')
if [ -n "$PR_NUMBER" ]; then
  gh pr merge $PR_NUMBER --auto --merge --delete-branch=false
  gum style --foreground 82 "Auto-merge enabled on PR #$PR_NUMBER"
  # Save current SHA as last PR base
  echo "$LOCAL_SHA" > "$LAST_PR_SHA_FILE"
  gum style --foreground 99 "Saved last PR SHA"
fi

echo ""
exit 0
